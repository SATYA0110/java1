pipeline {
    agent any
    tools {
    maven "maven"
    }
    environment {
        // Define any environment 
        PROJECT_NAME = "E-commerce-project-springBoot"
        GITHUB_REPO_URL = "https://github.com/SATYA0110/java1/blob/main/java_1/E-commerce-project-springBoot"
        DOCKER_IMAGE = "jt-spring-project"
        DOCKER_TAG   = "${BUILD_NUMBER}"
        // If pushing to Docker Hub, use: "your-dockerhub-user/jt-spring-project"
        REGISTRY_URL = "gcr.io/satyaproject-487714" 
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scmGit(branches: [[name: '*/main']], extensions: [], userRemoteConfigs: [[url: 'https://github.com/SATYA0110/java1.git']])
            }
        }
        
        stage('Build') {
            steps {
                // Build the project using Maven
                dir('java_1/E-commerce-project-springBoot'){
                sh 'ls -F'
                sh 'mvn clean package -DskipTests'
               }
            }
        }
        
        stage('Docker Image Build') {
            steps {
                script {
                    echo "Building Docker image: ${DOCKER_IMAGE}:${DOCKER_TAG}"
                    // This uses the Dockerfile in your repo root
                    sh "docker build -t ${DOCKER_IMAGE}:${DOCKER_TAG} ."
                    sh "docker tag ${DOCKER_IMAGE}:${DOCKER_TAG} ${DOCKER_IMAGE}:latest"
                }
            }
        }

        stage('Push to Registry') {
            steps {
                script {
                    // Requires 'Docker Pipeline' plugin and credentials configured in Jenkins
                    docker.withRegistry('https://gcr.io', 'gcp-registry-creds') {
                        sh "docker push ${DOCKER_IMAGE}:${DOCKER_TAG}"
                        sh "docker push ${DOCKER_IMAGE}:latest"
                    }
                }
            }
        }

        
        stage('Deploy') {
            steps {
                // Deploy the application (this can be customized as per your deployment process)
                // For example, copying the built JAR file to a specific location, or deploying to a cloud service
                sh '''
                echo "Deploying application..."
                # Example command: copying the built JAR file to a remote server
                # scp target/*.jar user@remote-server:/path/to/deployment/directory
                '''
            }
        }
    }
    
    post {
        always {
            // Actions to perform at the end of the pipeline
            // For example, cleaning up workspace, sending notifications, etc.
            cleanWs()
        }
        success {
            // Actions to perform if the pipeline succeeds
            echo 'Pipeline succeeded!'
        }
        failure {
            // Actions to perform if the pipeline fails
            echo 'Pipeline failed!'
        }
    }
}
